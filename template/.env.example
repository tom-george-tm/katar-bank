# Agent name must be a valid identifier (letters, digits, underscores only; no hyphens)
AGENT_NAME=my_agent
AGENT_DESCRIPTION=CHANGE_ME
AGENT_VERSION=CHANGE_ME
CLOUD_RUN_URL=CHANGE_ME
PORT=CHANGE_ME
GOOGLE_CLOUD_PROJECT=
ENABLE_CLOUD_TRACE=false

# Model provider (agent/core/model) – vertex_ai | garden
LLM_PROVIDER=vertex_ai
LLM_MODEL=gemini-2.0-flash
VERTEX_AI_LOCATION=us-central1
# Force google-genai to use Vertex AI backend (not Google AI Studio)
GOOGLE_GENAI_USE_VERTEXAI=TRUE
# For garden: set GARDEN_ENDPOINT_ID (path uses GOOGLE_CLOUD_PROJECT + VERTEX_AI_LOCATION)
# GARDEN_ENDPOINT_ID=

# Remote A2A sub-agent (sub_agents/remote_agent)
REMOTE_A2A_AGENT_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# State (session) management - SESSION_SERVICE_BACKEND
# inmemory | firestore | redis | memorystore | postgres | mongodb
# -----------------------------------------------------------------------------
SESSION_SERVICE_BACKEND=inmemory

# Firestore (when SESSION_SERVICE_BACKEND=firestore) – separate from other GCP config
FIRESTORE_PROJECT=
FIRESTORE_DATABASE=(default)
FIRESTORE_LOCATION=

# Redis / memorystore:
REDIS_URL=redis://localhost:6379/0
MEMORYSTORE_REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
# Postgres (uses ADK DatabaseSessionService; requires asyncpg)
# POSTGRES_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/adk_sessions
# MongoDB (custom BaseSessionService implementation; uses Motor)
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DATABASE=adk
# MONGODB_SESSIONS_COLLECTION=sessions

# -----------------------------------------------------------------------------
# Memory (long-term knowledge) - MEMORY_SERVICE_BACKEND
# none | inmemory | redis
# -----------------------------------------------------------------------------
MEMORY_SERVICE_BACKEND=inmemory

# Redis long-term memory (when MEMORY_SERVICE_BACKEND=redis): pip install adk-redis[memory]
# Requires Redis Agent Memory Server (e.g. http://localhost:8088)
REDIS_MEMORY_API_BASE_URL=http://localhost:8088
REDIS_MEMORY_NAMESPACE=adk_app
REDIS_MEMORY_EXTRACTION_STRATEGY=discrete
REDIS_MEMORY_RECENCY_BOOST=true

# -----------------------------------------------------------------------------
# Artifact storage - ARTIFACT_SERVICE_BACKEND
# none | inmemory | gcs
# -----------------------------------------------------------------------------
ARTIFACT_SERVICE_BACKEND=inmemory
GCS_ARTIFACT_BUCKET=

# MCP (optional)
# Supports both transports from the ADK + MCP guide:
# - SSE example: MCP_TRANSPORT=sse and MCP_SERVICE_URL=http://localhost:8001/sse
# - Streamable HTTP example: MCP_TRANSPORT=streamable_http and MCP_SERVICE_URL=http://localhost:3000/mcp
# MCP_TRANSPORT=sse
# MCP_SERVICE_URL=http://localhost:8001/sse
# MCP_API_KEY=

# OpenTelemetry (optional)
# OTEL_SERVICE_NAME=my-adk-agent
# ADK_CAPTURE_MESSAGE_CONTENT_IN_SPANS=false

# --- Server Config ---
PORT=8000

# --- Agent Metadata ---
AGENT_NAME="Vision Agent"
AGENT_DESCRIPTION="Intelligent Document Processing using OCR and Gemini Vision"
AGENT_VERSION="1.0.0"
CLOUD_RUN_URL="http://localhost:8000"

# --- Google Cloud Core ---
GOOGLE_CLOUD_PROJECT="your-project-id"
CREDENTIALS_PATH="path/to/service-account.json"

# --- Vertex AI (Gemini Vision) ---
VERTEX_AI_LOCATION="us-central1"
LLM_MODEL="gemini-2.0-flash"
GEMINI_MAX_OUTPUT_TOKENS=8192

# --- Document AI (OCR) ---
DOCAI_LOCATION="us"
DOCAI_FORM_PARSER_ID="a3b4fecd059ffa5d"
DOCAI_DOCUMENT_OCR_ID="a3b4fecd059ffa5d"
DOCAI_LAYOUT_PARSER_ID="your-layout-parser-id"

# --- Services (Defaults) ---
SESSION_SERVICE_BACKEND="inmemory"
MEMORY_SERVICE_BACKEND="inmemory"
ARTIFACT_SERVICE_BACKEND="inmemory"
